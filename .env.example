# UploadEz – Umgebungsvariablen
# Datei kopieren: cp .env.example .env  und Werte anpassen.
# NIEMALS .env in Git committen!

# ── Datenbank ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uploadez
DB_USER=uploadez_user
DB_PASS=sicheres_passwort_hier

# ── App-URL (ohne trailing slash) ───────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── SMTP / E-Mail ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=smtp_passwort_hier
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=UploadEz
SMTP_SECURE=tls
