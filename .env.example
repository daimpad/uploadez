# UploadEz – Umgebungsvariablen
# Datei kopieren: cp .env.example .env  und Werte anpassen.
# NIEMALS .env in Git committen!

# ── Datenbank ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uploadez
DB_USER=uploadez_user
DB_PASS=sicheres_passwort_hier

# ── App-URL (ohne trailing slash) ───────────────────────────────────────────
APP_URL=https://yourdomain.com

# ── SMTP / E-Mail ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=smtp_passwort_hier
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=UploadEz
SMTP_SECURE=tls

# ── Admin-Bereich ────────────────────────────────────────────────────────────
# Hash erzeugen: php -r "echo password_hash('deinPasswort', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=$2y$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Upload-Authentifizierung (optional) ──────────────────────────────────────
# Wenn gesetzt, müssen Nutzer diesen Code eingeben um hochladen zu dürfen.
# Leer lassen um Upload ohne Code zu erlauben.
UPLOAD_TOKEN=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=3600
